<Window x:Class="ConnectPad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConnectPad" Width="600" Height="460"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="#F7F8FA" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="ConnectPad" FontSize="24" FontWeight="SemiBold" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="DeviceBox" Height="38" VerticalContentAlignment="Center"
                      DisplayMemberPath="DisplayName" SelectionChanged="DeviceBox_SelectionChanged"
                      AutomationProperties.Name="设备" />
            <Button x:Name="RefreshButton" Grid.Column="2" Content="刷新" Click="RefreshButton_Click" />
        </Grid>

        <Button x:Name="StartButton" Grid.Row="4" Content="启动投屏" Height="42"
                FontWeight="SemiBold" IsEnabled="False" Click="StartButton_Click" />

        <TextBlock Grid.Row="6" Text="无线" FontSize="15" FontWeight="SemiBold" />

        <Grid Grid.Row="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="配对地址" Margin="0,0,0,5" Foreground="#5F6368" />
                <TextBox x:Name="PairEndpointBox" ToolTip="例如 192.168.1.8:37123"
                         AutomationProperties.Name="配对地址" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="配对码" Margin="0,0,0,5" Foreground="#5F6368" />
                <PasswordBox x:Name="PairCodeBox" MaxLength="6"
                             AutomationProperties.Name="配对码" />
            </StackPanel>
            <Button x:Name="PairButton" Grid.Column="4" Content="配对" VerticalAlignment="Bottom"
                    Click="PairButton_Click" />

            <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                <TextBlock Text="连接地址" Margin="0,0,0,5" Foreground="#5F6368" />
                <TextBox x:Name="ConnectEndpointBox" ToolTip="例如 192.168.1.8:42871"
                         AutomationProperties.Name="连接地址" />
            </StackPanel>
            <Button x:Name="ConnectButton" Grid.Row="2" Grid.Column="4" Content="连接"
                    VerticalAlignment="Bottom" Click="ConnectButton_Click" />
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="10" Text="正在检测设备…"
                   Foreground="#5F6368" TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>
